# Database
DATABASE_URL="postgresql://ftrepo:ftrepo@localhost:5432/ftrepo?schema=public"

# Telegram (TDLib)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_CHANNELS=channel1,channel2

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# App Store
APPSTORE_COUNTRY=us

# Application
NODE_ENV=development
PORT=3000
SCAN_INTERVAL_MINUTES=30
JSON_REGEN_INTERVAL_MINUTES=60
CLEANUP_INTERVAL_HOURS=24
MAX_VERSIONS_PER_APP=5
TEMP_DIR=/tmp/ftrepo
LOG_RETENTION_DAYS=30
